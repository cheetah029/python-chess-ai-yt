next(cell(F,R,C,P)) :- true(cell(F,R,C,P)) & does(MOVER,manipulate(QF,QR,EF,ER,TF,TR)) & distinct(F,EF) & distinct(R,TR)
next(cell(F,R,C,P)) :- true(cell(F,R,C,P)) & does(MOVER,manipulate(QF,QR,EF,ER,TF,TR)) & distinct(R,ER) & distinct(F,TF)
next(cell(F,R,C,P)) :- true(cell(F,R,C,P)) & does(MOVER,manipulate(QF,QR,EF,ER,TF,TR)) & distinct(R,ER) & distinct(R,TR)
