legal(PLAYER,manipulate(QF,QR,EF,ER,EF,TR)) :- true(control(PLAYER)) & true(cell(QF,QR,PLAYER,queen)) & true(queen_form(QF,QR,base)) & queen_los(QF,QR,EF,ER) & manipulable_target(PLAYER,EF,ER) & true(cell(EF,ER,OWNER,pawn)) & pawn_forward(OWNER,ER,TR) & ~last_rank(OWNER,TR) & ~occupied(EF,TR)
legal(PLAYER,manipulate(QF,QR,EF,ER,EF,TR)) :- true(control(PLAYER)) & true(cell(QF,QR,PLAYER,queen)) & true(queen_form(QF,QR,base)) & queen_los(QF,QR,EF,ER) & manipulable_target(PLAYER,EF,ER) & true(cell(EF,ER,OWNER,pawn)) & pawn_forward(OWNER,ER,TR) & ~last_rank(OWNER,TR) & enemy_at(OWNER,EF,TR) & ~true(invulnerable(EF,TR))
legal(PLAYER,manipulate(QF,QR,EF,ER,TF,TR)) :- true(control(PLAYER)) & true(cell(QF,QR,PLAYER,queen)) & true(queen_form(QF,QR,base)) & queen_los(QF,QR,EF,ER) & manipulable_target(PLAYER,EF,ER) & true(cell(EF,ER,OWNER,pawn)) & pawn_forward(OWNER,ER,TR) & ~last_rank(OWNER,TR) & file_adj(EF,TF) & enemy_at(OWNER,TF,TR) & ~true(invulnerable(TF,TR))
legal(PLAYER,manipulate(QF,QR,EF,ER,MF,MR)) :- true(control(PLAYER)) & true(cell(QF,QR,PLAYER,queen)) & true(queen_form(QF,QR,base)) & queen_los(QF,QR,EF,ER) & manipulable_target(PLAYER,EF,ER) & true(cell(EF,ER,OWNER,rook)) & rook_step(EF,ER,MF,MR,DIR1) & ~friend_at(OWNER,MF,MR) & ~true(invulnerable(MF,MR))
legal(PLAYER,manipulate(QF,QR,EF,ER,TF,TR)) :- true(control(PLAYER)) & true(cell(QF,QR,PLAYER,queen)) & true(queen_form(QF,QR,base)) & queen_los(QF,QR,EF,ER) & manipulable_target(PLAYER,EF,ER) & true(cell(EF,ER,OWNER,rook)) & rook_step(EF,ER,MF,MR,DIR1) & ~friend_at(OWNER,MF,MR) & ~occupied(MF,MR) & perpendicular(DIR1,DIR2) & sweep_path(MF,MR,TF,TR,DIR2) & ~friend_at(OWNER,TF,TR) & ~true(invulnerable(TF,TR))
legal(PLAYER,manipulate(QF,QR,EF,ER,TF,TR)) :- true(control(PLAYER)) & true(cell(QF,QR,PLAYER,queen)) & true(queen_form(QF,QR,base)) & queen_los(QF,QR,EF,ER) & manipulable_target(PLAYER,EF,ER) & true(cell(EF,ER,OWNER,knight)) & knight_step(EF,ER,TF,TR) & ~friend_at(OWNER,TF,TR) & ~true(invulnerable(TF,TR))
legal(PLAYER,move(queen,FF,FR,MF,MR)) :- true(control(PLAYER)) & true(cell(FF,FR,PLAYER,queen)) & true(queen_form(FF,FR,rook)) & rook_step(FF,FR,MF,MR,DIR1) & ~friend_at(PLAYER,MF,MR) & ~true(invulnerable(MF,MR)) & ~true(manipulation_freeze(FF,FR))
legal(PLAYER,move(queen,FF,FR,TF,TR)) :- true(control(PLAYER)) & true(cell(FF,FR,PLAYER,queen)) & true(queen_form(FF,FR,rook)) & rook_step(FF,FR,MF,MR,DIR1) & ~friend_at(PLAYER,MF,MR) & ~occupied(MF,MR) & perpendicular(DIR1,DIR2) & sweep_path(MF,MR,TF,TR,DIR2) & ~friend_at(PLAYER,TF,TR) & ~true(invulnerable(TF,TR)) & ~true(manipulation_freeze(FF,FR))
legal(PLAYER,move(queen,FF,FR,TF,TR)) :- true(control(PLAYER)) & true(cell(FF,FR,PLAYER,queen)) & true(queen_form(FF,FR,knight)) & knight_step(FF,FR,TF,TR) & ~friend_at(PLAYER,TF,TR) & ~true(invulnerable(TF,TR)) & ~true(manipulation_freeze(FF,FR))
legal(PLAYER,move(queen,FF,FR,TF,TR)) :- true(control(PLAYER)) & true(cell(FF,FR,PLAYER,queen)) & true(queen_form(FF,FR,bishop)) & file(TF) & rank(TR) & distinct(FF,TF) & empty(TF,TR) & ~enemy_can_reach(PLAYER,TF,TR) & ~true(manipulation_freeze(FF,FR))
legal(PLAYER,move(queen,FF,FR,TF,TR)) :- true(control(PLAYER)) & true(cell(FF,FR,PLAYER,queen)) & true(queen_form(FF,FR,bishop)) & file(TF) & rank(TR) & distinct(FR,TR) & empty(TF,TR) & ~enemy_can_reach(PLAYER,TF,TR) & ~true(manipulation_freeze(FF,FR))
next(queen_form(F,R,NEW_FORM)) :- does(MOVER,transform(F,R,NEW_FORM))
next(queen_form(F,R,FORM)) :- true(queen_form(F,R,FORM)) & true(cell(F,R,C,queen)) & ~queen_was_transformed_at(F,R) & ~square_touched(F,R)
queen_was_transformed_at(F,R) :- does(MOVER,transform(F,R,NEW_FORM))
next(queen_royal(F,R)) :- true(queen_royal(F,R)) & true(cell(F,R,C,queen)) & ~square_touched(F,R)
next(captured_friendly(OWNER,PIECE_TYPE)) :- does(MOVER,move(MOVING_PIECE,FF,FR,TF,TR)) & true(cell(TF,TR,OWNER,PIECE_TYPE)) & opponent(MOVER,OWNER) & distinct(OWNER,none)
next(captured_friendly(OWNER,PIECE_TYPE)) :- does(MOVER,manipulate(QF,QR,EF,ER,TF,TR)) & true(cell(TF,TR,OWNER,PIECE_TYPE)) & opponent(EF_OWNER,OWNER) & true(cell(EF,ER,EF_OWNER,EF_PIECE))
next(captured_friendly(OWNER,PIECE_TYPE)) :- true(captured_friendly(OWNER,PIECE_TYPE))
next(spatial_move_last_turn(TF,TR)) :- does(MOVER,move(PIECE,FF,FR,TF,TR)) & distinct(PIECE,boulder)
next(spatial_move_last_turn(TF,TR)) :- does(MOVER,manipulate(QF,QR,EF,ER,TF,TR))
next(manipulation_freeze(TF,TR)) :- does(MOVER,manipulate(QF,QR,EF,ER,TF,TR))
royal_queen_alive(PLAYER) :- true(cell(F,R,PLAYER,queen)) & true(queen_royal(F,R))
royal_queen_dead(PLAYER) :- ~royal_queen_alive(PLAYER)
alive(PLAYER,king) :- true(cell(F,R,PLAYER,king))
dead(PLAYER,king) :- ~alive(PLAYER,king)
lost(PLAYER) :- dead(PLAYER,king) & royal_queen_dead(PLAYER)
promo_form_available(OWNER,rook) :- true(captured_friendly(OWNER,rook))
promo_form_available(OWNER,bishop) :- true(captured_friendly(OWNER,bishop))
promo_form_available(OWNER,knight) :- true(captured_friendly(OWNER,knight))
next(captured_friendly(OWNER,PIECE_TYPE)) :- does(MOVER,promote(FF,FR,TF,TR,FORM)) & true(cell(TF,TR,OWNER,PIECE_TYPE))
next(spatial_move_last_turn(TF,TR)) :- does(MOVER,promote(FF,FR,TF,TR,FORM))
square_touched(F,R) :- does(M,move(P,F,R,TF,TR))
square_touched(F,R) :- does(M,move(P,FF,FR,F,R))
square_touched(F,R) :- does(M,manipulate(QF,QR,F,R,TF,TR))
square_touched(F,R) :- does(M,manipulate(QF,QR,EF,ER,F,R))
square_touched(F,R) :- does(M,jump_capture(F,R,TF,TR,JF,JR))
square_touched(F,R) :- does(M,jump_capture(FF,FR,F,R,JF,JR))
square_touched(F,R) :- does(M,jump_capture(FF,FR,TF,TR,F,R))
square_touched(F,R) :- does(M,reactive_capture(F,R,TF,TR))
square_touched(F,R) :- does(M,reactive_capture(BF,BR,F,R))
square_touched(F,R) :- does(M,promote(F,R,TF,TR,FORM))
square_touched(F,R) :- does(M,promote(FF,FR,F,R,FORM))
square_touched(F,R) :- does(M,manipulate_promote(QF,QR,F,R,TF,TR,FORM))
square_touched(F,R) :- does(M,manipulate_promote(QF,QR,EF,ER,F,R,FORM))
next(queen_form(TF,TR,FORM)) :- does(MOVER,move(queen,FF,FR,TF,TR)) & true(queen_form(FF,FR,FORM))
next(queen_royal(TF,TR)) :- does(MOVER,move(queen,FF,FR,TF,TR)) & true(queen_royal(FF,FR))
next(queen_form(TF,TR,FORM)) :- does(MOVER,manipulate(QF,QR,EF,ER,TF,TR)) & true(queen_form(EF,ER,FORM))
next(queen_royal(TF,TR)) :- does(MOVER,manipulate(QF,QR,EF,ER,TF,TR)) & true(queen_royal(EF,ER))
next(queen_form(TF,TR,FORM)) :- does(PLAYER,reactive_capture(BF,BR,TF,TR)) & true(queen_form(BF,BR,FORM))
next(queen_royal(TF,TR)) :- does(PLAYER,reactive_capture(BF,BR,TF,TR)) & true(queen_royal(BF,BR))
