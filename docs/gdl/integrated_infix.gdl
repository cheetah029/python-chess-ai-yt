next(queen_royal(TF,TR)) :- does(MOVER,jump_capture(FF,FR,TF,TR,JF,JR)) & true(queen_royal(FF,FR))
next(cell(TF,TR,OWNER,PIECE)) :- does(MOVER,manipulate(QF,QR,EF,ER,TF,TR)) & true(cell(EF,ER,OWNER,PIECE))
