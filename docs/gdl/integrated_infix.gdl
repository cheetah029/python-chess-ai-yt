legal(PLAYER,manipulate(QF,QR,EF,ER,TF,TR)) :- true(control(PLAYER)) & true(cell(QF,QR,PLAYER,queen)) & true(queen_form(QF,QR,base)) & queen_los(QF,QR,EF,ER) & manipulable_target(PLAYER,EF,ER) & true(cell(EF,ER,OWNER,bishop)) & file(TF) & rank(TR) & distinct(ER,TR) & empty(TF,TR) & ~enemy_can_reach(OWNER,TF,TR)
legal(PLAYER,manipulate(QF,QR,EF,ER,MF,MR)) :- true(control(PLAYER)) & true(cell(QF,QR,PLAYER,queen)) & true(queen_form(QF,QR,base)) & queen_los(QF,QR,EF,ER) & manipulable_target(PLAYER,EF,ER) & true(cell(EF,ER,OWNER,queen)) & true(queen_form(EF,ER,rook)) & rook_step(EF,ER,MF,MR,DIR1) & ~friend_at(OWNER,MF,MR) & ~true(invulnerable(MF,MR))
legal(PLAYER,manipulate(QF,QR,EF,ER,TF,TR)) :- true(control(PLAYER)) & true(cell(QF,QR,PLAYER,queen)) & true(queen_form(QF,QR,base)) & queen_los(QF,QR,EF,ER) & manipulable_target(PLAYER,EF,ER) & true(cell(EF,ER,OWNER,queen)) & true(queen_form(EF,ER,rook)) & rook_step(EF,ER,MF,MR,DIR1) & ~friend_at(OWNER,MF,MR) & ~occupied(MF,MR) & perpendicular(DIR1,DIR2) & sweep_path(MF,MR,TF,TR,DIR2) & ~friend_at(OWNER,TF,TR) & ~true(invulnerable(TF,TR))
legal(PLAYER,manipulate(QF,QR,EF,ER,TF,TR)) :- true(control(PLAYER)) & true(cell(QF,QR,PLAYER,queen)) & true(queen_form(QF,QR,base)) & queen_los(QF,QR,EF,ER) & manipulable_target(PLAYER,EF,ER) & true(cell(EF,ER,OWNER,queen)) & true(queen_form(EF,ER,knight)) & knight_step(EF,ER,TF,TR) & ~friend_at(OWNER,TF,TR) & ~true(invulnerable(TF,TR))
legal(PLAYER,manipulate(QF,QR,EF,ER,TF,TR)) :- true(control(PLAYER)) & true(cell(QF,QR,PLAYER,queen)) & true(queen_form(QF,QR,base)) & queen_los(QF,QR,EF,ER) & manipulable_target(PLAYER,EF,ER) & true(cell(EF,ER,OWNER,queen)) & true(queen_form(EF,ER,bishop)) & file(TF) & rank(TR) & distinct(EF,TF) & empty(TF,TR) & ~enemy_can_reach(OWNER,TF,TR)
legal(PLAYER,manipulate(QF,QR,EF,ER,TF,TR)) :- true(control(PLAYER)) & true(cell(QF,QR,PLAYER,queen)) & true(queen_form(QF,QR,base)) & queen_los(QF,QR,EF,ER) & manipulable_target(PLAYER,EF,ER) & true(cell(EF,ER,OWNER,queen)) & true(queen_form(EF,ER,bishop)) & file(TF) & rank(TR) & distinct(ER,TR) & empty(TF,TR) & ~enemy_can_reach(OWNER,TF,TR)
legal(PLAYER,manipulate_promote(QF,QR,EF,ER,EF,TR,FORM)) :- true(control(PLAYER)) & true(cell(QF,QR,PLAYER,queen)) & true(queen_form(QF,QR,base)) & queen_los(QF,QR,EF,ER) & manipulable_target(PLAYER,EF,ER) & true(cell(EF,ER,OWNER,pawn)) & pawn_forward(OWNER,ER,TR) & last_rank(OWNER,TR) & ~occupied(EF,TR) & promo_form_available(OWNER,FORM)
legal(PLAYER,manipulate_promote(QF,QR,EF,ER,EF,TR,FORM)) :- true(control(PLAYER)) & true(cell(QF,QR,PLAYER,queen)) & true(queen_form(QF,QR,base)) & queen_los(QF,QR,EF,ER) & manipulable_target(PLAYER,EF,ER) & true(cell(EF,ER,OWNER,pawn)) & pawn_forward(OWNER,ER,TR) & last_rank(OWNER,TR) & enemy_at(OWNER,EF,TR) & ~true(invulnerable(EF,TR)) & promo_form_available(OWNER,FORM)
legal(PLAYER,manipulate_promote(QF,QR,EF,ER,TF,TR,FORM)) :- true(control(PLAYER)) & true(cell(QF,QR,PLAYER,queen)) & true(queen_form(QF,QR,base)) & queen_los(QF,QR,EF,ER) & manipulable_target(PLAYER,EF,ER) & true(cell(EF,ER,OWNER,pawn)) & pawn_forward(OWNER,ER,TR) & last_rank(OWNER,TR) & file_adj(EF,TF) & enemy_at(OWNER,TF,TR) & ~true(invulnerable(TF,TR)) & promo_form_available(OWNER,FORM)
next(cell(TF,TR,OWNER,queen)) :- does(MOVER,manipulate_promote(QF,QR,EF,ER,TF,TR,FORM)) & true(cell(EF,ER,OWNER,pawn))
next(queen_form(TF,TR,FORM)) :- does(MOVER,manipulate_promote(QF,QR,EF,ER,TF,TR,FORM))
next(cell(F,R,C,P)) :- true(cell(F,R,C,P)) & does(MOVER,manipulate_promote(QF,QR,EF,ER,TF,TR,FORM)) & distinct(F,EF) & distinct(F,TF)
next(cell(F,R,C,P)) :- true(cell(F,R,C,P)) & does(MOVER,manipulate_promote(QF,QR,EF,ER,TF,TR,FORM)) & distinct(F,EF) & distinct(R,TR)
next(cell(F,R,C,P)) :- true(cell(F,R,C,P)) & does(MOVER,manipulate_promote(QF,QR,EF,ER,TF,TR,FORM)) & distinct(R,ER) & distinct(F,TF)
next(cell(F,R,C,P)) :- true(cell(F,R,C,P)) & does(MOVER,manipulate_promote(QF,QR,EF,ER,TF,TR,FORM)) & distinct(R,ER) & distinct(R,TR)
next(captured_friendly(OWNER,PIECE_TYPE)) :- does(MOVER,manipulate_promote(QF,QR,EF,ER,TF,TR,FORM)) & true(cell(TF,TR,OWNER,PIECE_TYPE))
next(manipulation_freeze(TF,TR)) :- does(MOVER,manipulate_promote(QF,QR,EF,ER,TF,TR,FORM))
next(spatial_move_last_turn(TF,TR)) :- does(MOVER,manipulate_promote(QF,QR,EF,ER,TF,TR,FORM))
has_any_legal_turn(PLAYER) :- legal(PLAYER,MOVE) & distinct(MOVE,noop)
lost(PLAYER) :- true(control(PLAYER)) & ~has_any_legal_turn(PLAYER)
knight_jumped_square(FF,FR,TF,FR,JF,FR) :- file_delta_2(FF,TF) & between_file(FF,TF,JF)
knight_jumped_square(FF,FR,FF,TR,FF,JR) :- rank_delta_2(FR,TR) & between_rank(FR,TR,JR)
knight_jumped_square(FF,FR,TF,TR,JF,JR) :- file_delta_2(FF,TF) & rank_delta_2(FR,TR) & between_file(FF,TF,JF) & between_rank(FR,TR,JR)
knight_jumped_square(FF,FR,TF,TR,JF,FR) :- file_delta_2(FF,TF) & rank_delta_1(FR,TR) & between_file(FF,TF,JF)
knight_jumped_square(FF,FR,TF,TR,FF,JR) :- file_delta_1(FF,TF) & rank_delta_2(FR,TR) & between_rank(FR,TR,JR)
between_file(a,c,b)
between_file(c,a,b)
between_file(b,d,c)
between_file(d,b,c)
between_file(c,e,d)
between_file(e,c,d)
between_file(d,f,e)
between_file(f,d,e)
between_file(e,g,f)
between_file(g,e,f)
between_file(f,h,g)
between_file(h,f,g)
between_rank(1,3,2)
between_rank(3,1,2)
between_rank(2,4,3)
between_rank(4,2,3)
between_rank(3,5,4)
between_rank(5,3,4)
between_rank(4,6,5)
between_rank(6,4,5)
between_rank(5,7,6)
between_rank(7,5,6)
between_rank(6,8,7)
between_rank(8,6,7)
legal(PLAYER,jump_capture(FF,FR,TF,TR,JF,JR)) :- true(control(PLAYER)) & true(cell(FF,FR,PLAYER,knight)) & knight_step(FF,FR,TF,TR) & empty(TF,TR) & knight_jumped_square(FF,FR,TF,TR,JF,JR) & enemy_at(PLAYER,JF,JR) & true(spatial_move_last_turn(JF,JR)) & ~true(invulnerable(JF,JR)) & ~true(manipulation_freeze(FF,FR))
next(invulnerable(TF,TR)) :- does(MOVER,move(knight,FF,FR,TF,TR)) & empty(TF,TR) & knight_jumped_square(FF,FR,TF,TR,JF,JR) & jumped_is_friend_or_boulder(MOVER,JF,JR) & adjacent_enemy_other_than_jumped(MOVER,TF,TR,JF,JR)
next(invulnerable(TF,TR)) :- does(MOVER,move(knight,FF,FR,TF,TR)) & empty(TF,TR) & knight_jumped_square(FF,FR,TF,TR,JF,JR) & jumped_is_enemy(MOVER,JF,JR) & adjacent_friendly_or_boulder_other_than_jumped(MOVER,TF,TR,JF,JR)
jumped_is_friend_or_boulder(MOVER,JF,JR) :- true(cell(JF,JR,MOVER,PIECE))
jumped_is_friend_or_boulder(MOVER,JF,JR) :- true(cell(JF,JR,none,boulder))
jumped_is_enemy(MOVER,JF,JR) :- true(cell(JF,JR,OTHER,PIECE)) & opponent(MOVER,OTHER)
adjacent_enemy_other_than_jumped(MOVER,TF,TR,JF,JR) :- true(cell(EF,ER,OTHER,PIECE)) & opponent(MOVER,OTHER) & king_step(TF,TR,EF,ER) & distinct(EF,JF)
adjacent_enemy_other_than_jumped(MOVER,TF,TR,JF,JR) :- true(cell(EF,ER,OTHER,PIECE)) & opponent(MOVER,OTHER) & king_step(TF,TR,EF,ER) & distinct(ER,JR)
adjacent_friendly_or_boulder_other_than_jumped(MOVER,TF,TR,JF,JR) :- true(cell(AF,AR,MOVER,PIECE)) & king_step(TF,TR,AF,AR) & distinct(AF,JF)
adjacent_friendly_or_boulder_other_than_jumped(MOVER,TF,TR,JF,JR) :- true(cell(AF,AR,MOVER,PIECE)) & king_step(TF,TR,AF,AR) & distinct(AR,JR)
adjacent_friendly_or_boulder_other_than_jumped(MOVER,TF,TR,JF,JR) :- true(cell(AF,AR,none,boulder)) & king_step(TF,TR,AF,AR) & distinct(AF,JF)
adjacent_friendly_or_boulder_other_than_jumped(MOVER,TF,TR,JF,JR) :- true(cell(AF,AR,none,boulder)) & king_step(TF,TR,AF,AR) & distinct(AR,JR)
next(cell(TF,TR,MOVER,knight)) :- does(MOVER,jump_capture(FF,FR,TF,TR,JF,JR)) & true(cell(FF,FR,MOVER,knight))
next(cell(TF,TR,MOVER,queen)) :- does(MOVER,jump_capture(FF,FR,TF,TR,JF,JR)) & true(cell(FF,FR,MOVER,queen))
next(cell(F,R,C,P)) :- true(cell(F,R,C,P)) & does(MOVER,jump_capture(FF,FR,TF,TR,JF,JR)) & distinct(F,FF) & distinct(F,TF) & distinct(F,JF)
next(cell(F,R,C,P)) :- true(cell(F,R,C,P)) & does(MOVER,jump_capture(FF,FR,TF,TR,JF,JR)) & distinct(F,FF) & distinct(F,TF) & distinct(R,JR)
next(cell(F,R,C,P)) :- true(cell(F,R,C,P)) & does(MOVER,jump_capture(FF,FR,TF,TR,JF,JR)) & distinct(F,FF) & distinct(R,TR) & distinct(F,JF)
next(cell(F,R,C,P)) :- true(cell(F,R,C,P)) & does(MOVER,jump_capture(FF,FR,TF,TR,JF,JR)) & distinct(F,FF) & distinct(R,TR) & distinct(R,JR)
next(cell(F,R,C,P)) :- true(cell(F,R,C,P)) & does(MOVER,jump_capture(FF,FR,TF,TR,JF,JR)) & distinct(R,FR) & distinct(F,TF) & distinct(F,JF)
next(cell(F,R,C,P)) :- true(cell(F,R,C,P)) & does(MOVER,jump_capture(FF,FR,TF,TR,JF,JR)) & distinct(R,FR) & distinct(F,TF) & distinct(R,JR)
next(cell(F,R,C,P)) :- true(cell(F,R,C,P)) & does(MOVER,jump_capture(FF,FR,TF,TR,JF,JR)) & distinct(R,FR) & distinct(R,TR) & distinct(F,JF)
next(cell(F,R,C,P)) :- true(cell(F,R,C,P)) & does(MOVER,jump_capture(FF,FR,TF,TR,JF,JR)) & distinct(R,FR) & distinct(R,TR) & distinct(R,JR)
next(captured_friendly(OWNER,PIECE_TYPE)) :- does(MOVER,jump_capture(FF,FR,TF,TR,JF,JR)) & true(cell(JF,JR,OWNER,PIECE_TYPE))
legal(PLAYER,jump_capture(FF,FR,TF,TR,JF,JR)) :- true(control(PLAYER)) & true(cell(FF,FR,PLAYER,queen)) & true(queen_form(FF,FR,knight)) & knight_step(FF,FR,TF,TR) & empty(TF,TR) & knight_jumped_square(FF,FR,TF,TR,JF,JR) & enemy_at(PLAYER,JF,JR) & true(spatial_move_last_turn(JF,JR)) & ~true(invulnerable(JF,JR)) & ~true(manipulation_freeze(FF,FR))
next(invulnerable(TF,TR)) :- does(MOVER,move(queen,FF,FR,TF,TR)) & true(queen_form(FF,FR,knight)) & empty(TF,TR) & knight_jumped_square(FF,FR,TF,TR,JF,JR) & jumped_is_friend_or_boulder(MOVER,JF,JR) & adjacent_enemy_other_than_jumped(MOVER,TF,TR,JF,JR)
next(invulnerable(TF,TR)) :- does(MOVER,move(queen,FF,FR,TF,TR)) & true(queen_form(FF,FR,knight)) & empty(TF,TR) & knight_jumped_square(FF,FR,TF,TR,JF,JR) & jumped_is_enemy(MOVER,JF,JR) & adjacent_friendly_or_boulder_other_than_jumped(MOVER,TF,TR,JF,JR)
next(spatial_move_last_turn(TF,TR)) :- does(MOVER,jump_capture(FF,FR,TF,TR,JF,JR))
next(spatial_move_last_turn(TF,TR)) :- does(PLAYER,reactive_capture(BF,BR,TF,TR))
bishop_diag_los(BF,BR,TF,TR) :- queen_los_diag(BF,BR,TF,TR)
next(reactive_armed(BF,BR,TF,TR)) :- does(MOVER,move(PIECE,FF,FR,TF,TR)) & distinct(PIECE,boulder) & opponent(MOVER,ENEMY) & true(cell(BF,BR,ENEMY,bishop)) & bishop_diag_los(BF,BR,FF,FR)
next(reactive_armed(BF,BR,TF,TR)) :- does(MOVER,manipulate(QF,QR,EF,ER,TF,TR)) & true(cell(BF,BR,MOVER,bishop)) & bishop_diag_los(BF,BR,EF,ER)
next(reactive_armed(BF,BR,TF,TR)) :- does(MOVER,jump_capture(FF,FR,TF,TR,JF,JR)) & opponent(MOVER,ENEMY) & true(cell(BF,BR,ENEMY,bishop)) & bishop_diag_los(BF,BR,FF,FR)
next(reactive_armed(BF,BR,TF,TR)) :- does(MOVER,reactive_capture(OF,OR,TF,TR)) & opponent(MOVER,ENEMY) & true(cell(BF,BR,ENEMY,bishop)) & bishop_diag_los(BF,BR,OF,OR)
legal(PLAYER,reactive_capture(BF,BR,TF,TR)) :- true(control(PLAYER)) & true(cell(BF,BR,PLAYER,bishop)) & true(reactive_armed(BF,BR,TF,TR)) & true(cell(TF,TR,ENEMY,PIECE)) & opponent(PLAYER,ENEMY) & ~true(invulnerable(TF,TR)) & ~true(manipulation_freeze(BF,BR))
next(cell(TF,TR,PLAYER,bishop)) :- does(PLAYER,reactive_capture(BF,BR,TF,TR)) & true(cell(BF,BR,PLAYER,bishop))
next(cell(TF,TR,PLAYER,queen)) :- does(PLAYER,reactive_capture(BF,BR,TF,TR)) & true(cell(BF,BR,PLAYER,queen))
next(cell(F,R,C,P)) :- true(cell(F,R,C,P)) & does(PLAYER,reactive_capture(BF,BR,TF,TR)) & distinct(F,BF) & distinct(F,TF)
next(cell(F,R,C,P)) :- true(cell(F,R,C,P)) & does(PLAYER,reactive_capture(BF,BR,TF,TR)) & distinct(F,BF) & distinct(R,TR)
next(cell(F,R,C,P)) :- true(cell(F,R,C,P)) & does(PLAYER,reactive_capture(BF,BR,TF,TR)) & distinct(R,BR) & distinct(F,TF)
next(cell(F,R,C,P)) :- true(cell(F,R,C,P)) & does(PLAYER,reactive_capture(BF,BR,TF,TR)) & distinct(R,BR) & distinct(R,TR)
queen_as_bishop_at(F,R,OWNER) :- true(cell(F,R,OWNER,queen)) & true(queen_form(F,R,bishop))
next(reactive_armed(BF,BR,TF,TR)) :- does(MOVER,move(PIECE,FF,FR,TF,TR)) & distinct(PIECE,boulder) & opponent(MOVER,ENEMY) & queen_as_bishop_at(BF,BR,ENEMY) & bishop_diag_los(BF,BR,FF,FR)
next(reactive_armed(BF,BR,TF,TR)) :- does(MOVER,manipulate(QF,QR,EF,ER,TF,TR)) & queen_as_bishop_at(BF,BR,MOVER) & bishop_diag_los(BF,BR,EF,ER)
next(reactive_armed(BF,BR,TF,TR)) :- does(MOVER,jump_capture(FF,FR,TF,TR,JF,JR)) & opponent(MOVER,ENEMY) & queen_as_bishop_at(BF,BR,ENEMY) & bishop_diag_los(BF,BR,FF,FR)
next(reactive_armed(BF,BR,TF,TR)) :- does(MOVER,reactive_capture(OF,OR,TF,TR)) & opponent(MOVER,ENEMY) & queen_as_bishop_at(BF,BR,ENEMY) & bishop_diag_los(BF,BR,OF,OR)
legal(PLAYER,reactive_capture(BF,BR,TF,TR)) :- true(control(PLAYER)) & queen_as_bishop_at(BF,BR,PLAYER) & true(reactive_armed(BF,BR,TF,TR)) & true(cell(TF,TR,ENEMY,PIECE)) & opponent(PLAYER,ENEMY) & ~true(invulnerable(TF,TR)) & ~true(manipulation_freeze(BF,BR))
next(reactive_armed(BF,BR,TF,TR)) :- does(MOVER,promote(FF,FR,TF,TR,FORM)) & opponent(MOVER,ENEMY) & true(cell(BF,BR,ENEMY,bishop)) & bishop_diag_los(BF,BR,FF,FR)
next(reactive_armed(BF,BR,TF,TR)) :- does(MOVER,promote(FF,FR,TF,TR,FORM)) & opponent(MOVER,ENEMY) & queen_as_bishop_at(BF,BR,ENEMY) & bishop_diag_los(BF,BR,FF,FR)
next(reactive_armed(BF,BR,TF,TR)) :- does(MOVER,manipulate_promote(QF,QR,EF,ER,TF,TR,FORM)) & true(cell(BF,BR,MOVER,bishop)) & bishop_diag_los(BF,BR,EF,ER)
next(reactive_armed(BF,BR,TF,TR)) :- does(MOVER,manipulate_promote(QF,QR,EF,ER,TF,TR,FORM)) & queen_as_bishop_at(BF,BR,MOVER) & bishop_diag_los(BF,BR,EF,ER)
next(captured_friendly(OWNER,PIECE_TYPE)) :- does(PLAYER,reactive_capture(BF,BR,TF,TR)) & true(cell(TF,TR,OWNER,PIECE_TYPE))
legal(PLAYER,manipulate(QF,QR,EF,ER,TF,TR)) :- true(control(PLAYER)) & true(cell(QF,QR,PLAYER,queen)) & true(queen_form(QF,QR,base)) & queen_los(QF,QR,EF,ER) & manipulable_target(PLAYER,EF,ER) & true(cell(EF,ER,OWNER,bishop)) & true(reactive_armed(EF,ER,TF,TR)) & enemy_at(OWNER,TF,TR) & ~true(invulnerable(TF,TR))
legal(PLAYER,manipulate(QF,QR,EF,ER,TF,TR)) :- true(control(PLAYER)) & true(cell(QF,QR,PLAYER,queen)) & true(queen_form(QF,QR,base)) & queen_los(QF,QR,EF,ER) & manipulable_target(PLAYER,EF,ER) & true(cell(EF,ER,OWNER,queen)) & true(queen_form(EF,ER,bishop)) & true(reactive_armed(EF,ER,TF,TR)) & enemy_at(OWNER,TF,TR) & ~true(invulnerable(TF,TR))
would_repeat_third_time(NEXT_HASH) :- true(state_repetition_count(NEXT_HASH,2))
legal_after_repetition_filter(PLAYER,MOVE,NEXT_HASH) :- legal(PLAYER,MOVE) & ~would_repeat_third_time(NEXT_HASH)
next(state_repetition_count(HASH,NEW_COUNT)) :- true(next_state_hash(HASH)) & true(state_repetition_count(HASH,OLD_COUNT)) & succ(OLD_COUNT,NEW_COUNT)
succ(0,1)
all_legal_repetition_blocked(PLAYER) :- legal(PLAYER,MOVE) & would_repeat_third_time(DUMMY)
lost(PLAYER) :- no_legal_after_repetition_filter(PLAYER)
no_legal_after_repetition_filter(PLAYER) :- true(control(PLAYER)) & ~some_legal_after_repetition_filter(PLAYER)
some_legal_after_repetition_filter(PLAYER) :- legal_after_repetition_filter(PLAYER,MOVE,HASH)
pawnless :- ~any_pawn
any_pawn :- true(cell(F,R,C,pawn))
non_king_non_boulder_count_at_most(6) :- ~at_least_7_non_king_non_boulder
at_least_7_non_king_non_boulder :- counts_at_least_7
tiny_balanced :- cancel_queens_valuation_balanced
tiny_endgame_active :- pawnless & non_king_non_boulder_count_at_most(6) & tiny_balanced
royal_distance(D) :- closest_royal_pair_distance(D)
next(distance_count(D,1)) :- true(tiny_endgame_active) & royal_distance(D) & just_activated
just_activated :- true(tiny_endgame_active) & ~was_active_last_turn
next(distance_count(D,NEW)) :- true(tiny_endgame_active) & not_a_capture_turn & royal_distance(D) & true(distance_count(D,OLD)) & succ(OLD,NEW)
next(distance_count(D,0)) :- a_capture_turn & true(distance_count(D,OLD)) & distinct(D,CURRENT)
next(distance_count(CURRENT,1)) :- a_capture_turn & true(tiny_endgame_active) & royal_distance(CURRENT)
a_capture_turn :- does(MOVER,move(PIECE,FF,FR,TF,TR)) & occupied(TF,TR)
not_a_capture_turn :- ~a_capture_turn
tiny_endgame_limit_exceeded(D) :- true(distance_count(D,3))
legal_after_tiny_filter(PLAYER,MOVE) :- legal(PLAYER,MOVE) & would_be_capture(MOVE)
legal_after_tiny_filter(PLAYER,MOVE) :- legal(PLAYER,MOVE) & ~tiny_endgame_limit_exceeded(NEXT_D)
would_be_capture(move(PIECE,FF,FR,TF,TR)) :- occupied(TF,TR)
lost(PLAYER) :- true(control(PLAYER)) & true(tiny_endgame_active) & no_legal_after_tiny_filter(PLAYER)
no_legal_after_tiny_filter(PLAYER) :- ~some_legal_after_tiny_filter(PLAYER)
some_legal_after_tiny_filter(PLAYER) :- legal_after_tiny_filter(PLAYER,MOVE)
